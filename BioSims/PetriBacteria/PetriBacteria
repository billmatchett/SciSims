<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Petri Dish Bacterial Growth Simulator</title>
  <style>
    :root {
      --bg: #eef3f7;
      --panel: #ffffff;
      --line: #d3dde6;
      --text: #1d2a33;
      --muted: #5e6e79;
      --accent: #2f6fed;
      --accent2: #18a999;
      --danger: #d94f4f;
      --dish-rim: #a9bccd;
      --agar: #f4e8b5;
      --agar2: #efe0a0;
      --shadow: rgba(20, 35, 50, 0.08);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: radial-gradient(circle at top, #f9fbfd 0%, var(--bg) 70%);
      color: var(--text);
    }

    .app {
      max-width: 1300px;
      margin: 0 auto;
      padding: 18px;
      display: grid;
      grid-template-columns: 340px 1fr;
      gap: 18px;
    }

    .panel, .stage {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 18px;
      box-shadow: 0 10px 28px var(--shadow);
    }

    .panel {
      padding: 18px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    h1 {
      margin: 0;
      font-size: 1.45rem;
      line-height: 1.2;
    }

    .sub {
      color: var(--muted);
      font-size: 0.95rem;
      line-height: 1.4;
    }

    .group {
      border-top: 1px solid var(--line);
      padding-top: 14px;
      display: grid;
      gap: 10px;
    }

    .row {
      display: grid;
      gap: 6px;
    }

    .label-line {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      font-size: 0.95rem;
      font-weight: 700;
    }

    .value {
      color: var(--accent);
      font-weight: 700;
    }

    input[type="range"] {
      width: 100%;
      cursor: pointer;
    }

    .btn-row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    button {
      border: none;
      border-radius: 12px;
      padding: 12px 14px;
      font-size: 0.95rem;
      font-weight: 700;
      cursor: pointer;
      background: #e9eef5;
      color: var(--text);
      transition: transform 0.08s ease, opacity 0.2s ease;
    }

    button:hover { opacity: 0.95; }
    button:active { transform: scale(0.98); }
    button.primary { background: var(--accent); color: white; }
    button.green { background: var(--accent2); color: white; }
    button.red { background: var(--danger); color: white; }

    .stage {
      padding: 16px;
      display: grid;
      grid-template-rows: auto 1fr auto;
      gap: 12px;
      min-height: 760px;
    }

    .stage-top {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: 10px;
      align-items: center;
    }

    .badge-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .badge {
      padding: 8px 10px;
      border-radius: 999px;
      background: #f4f7fb;
      border: 1px solid var(--line);
      font-size: 0.9rem;
      font-weight: 700;
    }

    .canvas-wrap {
      position: relative;
      display: grid;
      place-items: center;
      overflow: hidden;
      border-radius: 18px;
      background: linear-gradient(180deg, #fbfcfe 0%, #f2f6fa 100%);
      min-height: 580px;
    }

    canvas {
      width: min(90vw, 820px);
      height: min(90vw, 820px);
      max-width: 820px;
      max-height: 820px;
      aspect-ratio: 1 / 1;
      display: block;
    }

    .legend {
      display: flex;
      flex-wrap: wrap;
      gap: 18px;
      font-size: 0.92rem;
      color: var(--muted);
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .dot {
      width: 14px;
      height: 14px;
      border-radius: 50%;
      display: inline-block;
      border: 1px solid rgba(0,0,0,0.1);
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(4, minmax(120px, 1fr));
      gap: 10px;
    }

    .stat-card {
      background: #f8fafc;
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 12px;
    }

    .stat-label {
      font-size: 0.82rem;
      color: var(--muted);
      margin-bottom: 4px;
    }

    .stat-value {
      font-size: 1.15rem;
      font-weight: 700;
    }

    .note {
      font-size: 0.88rem;
      color: var(--muted);
      line-height: 1.45;
    }

    .checkbox-row {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 0.95rem;
      font-weight: 700;
    }

    @media (max-width: 980px) {
      .app {
        grid-template-columns: 1fr;
      }

      .stage {
        min-height: unset;
      }

      .stats {
        grid-template-columns: repeat(2, minmax(120px, 1fr));
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <aside class="panel">
      <div>
        <h1>Petri Dish Bacterial Growth Simulator</h1>
        <div class="sub">A simplified colony growth model for classroom use. Students can explore how nutrient level, moisture, temperature, and antibiotics influence the spread of bacteria across an agar plate.</div>
      </div>

      <div class="btn-row">
        <button id="playPauseBtn">Play</button>
        <button id="resetBtn" class="red">Reset</button>
      </div>

      <div class="btn-row">
        <button id="step1Btn">Move 1 hour</button>
        <button id="step10Btn">Move 10 hours</button>
      </div>

      <div class="btn-row">
        <button id="seedBtn" class="green">Add Colony</button>
        <button id="antibioticBtn">Toggle Antibiotic Disc</button>
      </div>

      <div class="group">
        <div class="row">
          <div class="label-line"><span>Simulation speed</span><span id="speedValue" class="value">1.0×</span></div>
          <input id="speed" type="range" min="0.2" max="3" step="0.1" value="1" />
        </div>
        <div class="row">
          <div class="label-line"><span>Starting colonies</span><span id="coloniesValue" class="value">3</span></div>
          <input id="colonies" type="range" min="1" max="8" step="1" value="3" />
        </div>
        <div class="row">
          <div class="label-line"><span>Nutrient level</span><span id="nutrientsValue" class="value">70%</span></div>
          <input id="nutrients" type="range" min="10" max="100" step="1" value="70" />
        </div>
        <div class="row">
          <div class="label-line"><span>Moisture</span><span id="moistureValue" class="value">65%</span></div>
          <input id="moisture" type="range" min="10" max="100" step="1" value="65" />
        </div>
        <div class="row">
          <div class="label-line"><span>Temperature</span><span id="temperatureValue" class="value">32°C</span></div>
          <input id="temperature" type="range" min="5" max="45" step="1" value="32" />
        </div>
        <div class="row">
          <div class="label-line"><span>Antibiotic strength</span><span id="antibioticStrengthValue" class="value">65%</span></div>
          <input id="antibioticStrength" type="range" min="0" max="100" step="1" value="65" />
        </div>
      </div>

      <div class="group">
        <label class="checkbox-row"><input id="showGrid" type="checkbox" /> Show grid</label>
        <label class="checkbox-row"><input id="showHeat" type="checkbox" checked /> Show growth shading</label>
        <label class="checkbox-row"><input id="edgePenalty" type="checkbox" checked /> Stronger edge limits</label>
      </div>

      <div class="group note">
        This model is deliberately simplified. It does not represent a specific bacterial species or exact microbiology kinetics. It is best used to show general ideas such as colony expansion, competition for space, and inhibition zones around antibiotics.
      </div>
    </aside>

    <main class="stage">
      <div class="stage-top">
        <div class="badge-row">
          <div class="badge" id="growthBadge">Growth conditions: good</div>
          <div class="badge" id="antibioticBadge">Antibiotic disc: off</div>
          <div class="badge" id="phaseBadge">Phase: exponential</div>
        </div>
      </div>

      <div class="canvas-wrap">
        <canvas id="dishCanvas" width="900" height="900"></canvas>
      </div>

      <div>
        <div class="stats">
          <div class="stat-card">
            <div class="stat-label">Occupied area</div>
            <div class="stat-value" id="occupiedStat">0%</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Estimated population</div>
            <div class="stat-value" id="populationStat">0</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Average growth index</div>
            <div class="stat-value" id="growthStat">0.00</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Elapsed time</div>
            <div class="stat-value" id="timeStat">0.0 h</div>
          </div>
        </div>

        <div class="legend" style="margin-top: 12px;">
          <div class="legend-item"><span class="dot" style="background:#f0df9c"></span>Agar</div>
          <div class="legend-item"><span class="dot" style="background:#7ec87e"></span>Young growth</div>
          <div class="legend-item"><span class="dot" style="background:#35865f"></span>Dense colony</div>
          <div class="legend-item"><span class="dot" style="background:#d9e8f7"></span>Antibiotic zone</div>
        </div>
      </div>
    </main>
  </div>

  <script>
    const canvas = document.getElementById('dishCanvas');
    const ctx = canvas.getContext('2d');

    const speedInput = document.getElementById('speed');
    const coloniesInput = document.getElementById('colonies');
    const nutrientsInput = document.getElementById('nutrients');
    const moistureInput = document.getElementById('moisture');
    const temperatureInput = document.getElementById('temperature');
    const antibioticStrengthInput = document.getElementById('antibioticStrength');
    const showGridInput = document.getElementById('showGrid');
    const showHeatInput = document.getElementById('showHeat');
    const edgePenaltyInput = document.getElementById('edgePenalty');

    const speedValue = document.getElementById('speedValue');
    const coloniesValue = document.getElementById('coloniesValue');
    const nutrientsValue = document.getElementById('nutrientsValue');
    const moistureValue = document.getElementById('moistureValue');
    const temperatureValue = document.getElementById('temperatureValue');
    const antibioticStrengthValue = document.getElementById('antibioticStrengthValue');

    const playPauseBtn = document.getElementById('playPauseBtn');
    const resetBtn = document.getElementById('resetBtn');
    const step1Btn = document.getElementById('step1Btn');
    const step10Btn = document.getElementById('step10Btn');
    const seedBtn = document.getElementById('seedBtn');
    const antibioticBtn = document.getElementById('antibioticBtn');

    const growthBadge = document.getElementById('growthBadge');
    const antibioticBadge = document.getElementById('antibioticBadge');
    const phaseBadge = document.getElementById('phaseBadge');

    const occupiedStat = document.getElementById('occupiedStat');
    const populationStat = document.getElementById('populationStat');
    const growthStat = document.getElementById('growthStat');
    const timeStat = document.getElementById('timeStat');

    const GRID = 120;
    const SIZE = canvas.width;
    const CELL = SIZE / GRID;
    const CX = SIZE / 2;
    const CY = SIZE / 2;
    const DISH_RADIUS = SIZE * 0.39;
    const ANTIBIOTIC_RADIUS = SIZE * 0.07;
    const ANTIBIOTIC_EFFECT_RADIUS = SIZE * 0.19;

    let cells = [];
    let nextCells = [];
    let running = false;
    let antibioticOn = false;
    let elapsedHours = 0;
    let steps = 0;
    let lastTime = 0;

    function makeGrid() {
      cells = new Array(GRID * GRID).fill(0);
      nextCells = new Array(GRID * GRID).fill(0);
    }

    function idx(x, y) {
      return y * GRID + x;
    }

    function inBounds(x, y) {
      return x >= 0 && x < GRID && y >= 0 && y < GRID;
    }

    function cellCenter(x, y) {
      return {
        px: x * CELL + CELL / 2,
        py: y * CELL + CELL / 2
      };
    }

    function insideDish(x, y) {
      const { px, py } = cellCenter(x, y);
      const dx = px - CX;
      const dy = py - CY;
      return Math.hypot(dx, dy) <= DISH_RADIUS;
    }

    function distanceFromDishCentre(x, y) {
      const { px, py } = cellCenter(x, y);
      return Math.hypot(px - CX, py - CY);
    }

    function distanceFromAntibiotic(x, y) {
      const { px, py } = cellCenter(x, y);
      return Math.hypot(px - CX, py - CY);
    }

    function randomDishCell() {
      for (let i = 0; i < 5000; i++) {
        const x = Math.floor(Math.random() * GRID);
        const y = Math.floor(Math.random() * GRID);
        if (insideDish(x, y)) return { x, y };
      }
      return { x: Math.floor(GRID / 2), y: Math.floor(GRID / 2) };
    }

    function seedColonies(count) {
      for (let i = 0; i < count; i++) {
        const { x, y } = randomDishCell();
        const base = idx(x, y);
        cells[base] = Math.max(cells[base], 0.55 + Math.random() * 0.25);

        for (let oy = -2; oy <= 2; oy++) {
          for (let ox = -2; ox <= 2; ox++) {
            const nx = x + ox;
            const ny = y + oy;
            if (!inBounds(nx, ny) || !insideDish(nx, ny)) continue;
            const d = Math.hypot(ox, oy);
            if (d <= 2.2) {
              const strength = Math.max(0, 0.42 - d * 0.12 + Math.random() * 0.06);
              cells[idx(nx, ny)] = Math.max(cells[idx(nx, ny)], strength);
            }
          }
        }
      }
    }

    function environmentFactor() {
      const nutrients = Number(nutrientsInput.value) / 100;
      const moisture = Number(moistureInput.value) / 100;
      const temp = Number(temperatureInput.value);
      const tempFactor = Math.max(0, 1 - Math.abs(temp - 34) / 18);
      return 0.25 + nutrients * 0.38 + moisture * 0.22 + tempFactor * 0.35;
    }

    function updatePlayPauseButton() {
      playPauseBtn.textContent = running ? 'Pause' : 'Play';
      playPauseBtn.classList.toggle('primary', running);
    }

    function updateReadouts() {
      speedValue.textContent = `${Number(speedInput.value).toFixed(1)}×`;
      coloniesValue.textContent = coloniesInput.value;
      nutrientsValue.textContent = `${nutrientsInput.value}%`;
      moistureValue.textContent = `${moistureInput.value}%`;
      temperatureValue.textContent = `${temperatureInput.value}°C`;
      antibioticStrengthValue.textContent = `${antibioticStrengthInput.value}%`;

      const env = environmentFactor();
      growthBadge.textContent = `Growth conditions: ${env > 0.8 ? 'excellent' : env > 0.62 ? 'good' : env > 0.45 ? 'moderate' : 'poor'}`;
      antibioticBadge.textContent = `Antibiotic disc: ${antibioticOn ? 'on' : 'off'}`;
      updatePlayPauseButton();
    }

    function growthPhase(occupiedFraction) {
      if (occupiedFraction < 0.08) return 'lag';
      if (occupiedFraction < 0.55) return 'exponential';
      if (occupiedFraction < 0.82) return 'slowing';
      return 'stationary';
    }

    function neighbourStats(x, y) {
      let sum = 0;
      let count = 0;
      let occupiedNeighbours = 0;
      for (let oy = -1; oy <= 1; oy++) {
        for (let ox = -1; ox <= 1; ox++) {
          if (ox === 0 && oy === 0) continue;
          const nx = x + ox;
          const ny = y + oy;
          if (!inBounds(nx, ny) || !insideDish(nx, ny)) continue;
          const value = cells[idx(nx, ny)];
          sum += value;
          count++;
          if (value > 0.08) occupiedNeighbours++;
        }
      }
      return { sum, count, occupiedNeighbours };
    }

    function inhibitionFactor(x, y) {
      if (!antibioticOn) return 1;
      const strength = Number(antibioticStrengthInput.value) / 100;
      const d = distanceFromAntibiotic(x, y);
      if (d < ANTIBIOTIC_RADIUS) return 0;
      if (d > ANTIBIOTIC_EFFECT_RADIUS) return 1;
      const t = (d - ANTIBIOTIC_RADIUS) / (ANTIBIOTIC_EFFECT_RADIUS - ANTIBIOTIC_RADIUS);
      return Math.max(0, Math.min(1, t + (1 - strength) * 0.55));
    }

    function edgeFactor(x, y) {
      if (!edgePenaltyInput.checked) return 1;
      const d = distanceFromDishCentre(x, y);
      const t = d / DISH_RADIUS;
      if (t < 0.7) return 1;
      return Math.max(0.4, 1 - (t - 0.7) * 1.5);
    }

    function stepSimulation(dt) {
      const env = environmentFactor();
      const timeScale = Number(speedInput.value);
      const effectiveDt = dt * timeScale;
      elapsedHours += effectiveDt * 0.09;
      steps++;

      let occupied = 0;
      let totalPop = 0;
      let growthAccumulator = 0;
      let availableCells = 0;

      for (let y = 0; y < GRID; y++) {
        for (let x = 0; x < GRID; x++) {
          const i = idx(x, y);
          if (!insideDish(x, y)) {
            nextCells[i] = 0;
            continue;
          }

          availableCells++;
          const current = cells[i];
          const { sum, count, occupiedNeighbours } = neighbourStats(x, y);
          const avgNeighbours = count ? sum / count : 0;
          const crowding = Math.min(1, current + avgNeighbours * 0.85);
          const localSpace = 1 - Math.min(1, crowding);
          const inhibition = inhibitionFactor(x, y);
          const edge = edgeFactor(x, y);

          let growth = 0;
          if (current > 0.01) {
            growth += env * 0.032 * current * localSpace * inhibition * edge;
            growth += occupiedNeighbours * 0.0024 * env * inhibition;
          } else {
            if (occupiedNeighbours >= 2) {
              growth += avgNeighbours * 0.05 * env * inhibition * edge;
            }
          }

          const decay = 0.004 + Math.max(0, crowding - 0.78) * 0.022 + (1 - inhibition) * 0.025;
          const drift = (Math.random() - 0.5) * 0.012;
          let next = current + growth * effectiveDt - decay * effectiveDt + drift * effectiveDt;

          next = Math.max(0, Math.min(1, next));
          if (next < 0.015) next = 0;

          nextCells[i] = next;
          if (next > 0.05) occupied++;
          totalPop += next;
          growthAccumulator += growth;
        }
      }

      [cells, nextCells] = [nextCells, cells];

      const occupiedFraction = availableCells ? occupied / availableCells : 0;
      phaseBadge.textContent = `Phase: ${growthPhase(occupiedFraction)}`;
      occupiedStat.textContent = `${(occupiedFraction * 100).toFixed(1)}%`;
      populationStat.textContent = `${Math.round(totalPop * 1200).toLocaleString()}`;
      growthStat.textContent = `${Math.max(0, growthAccumulator / Math.max(1, availableCells) * 100).toFixed(2)}`;
      timeStat.textContent = `${elapsedHours.toFixed(1)} h`;
    }

    function advanceHours(hours) {
      const timeScale = Math.max(0.1, Number(speedInput.value));
      const targetEffectiveDt = hours / 0.09;
      let remainingEffectiveDt = targetEffectiveDt;
      const chunkEffectiveDt = 0.8;

      while (remainingEffectiveDt > 0) {
        const currentChunkEffectiveDt = Math.min(chunkEffectiveDt, remainingEffectiveDt);
        const rawDt = currentChunkEffectiveDt / timeScale;
        stepSimulation(rawDt);
        remainingEffectiveDt -= currentChunkEffectiveDt;
      }

      drawDish();
    }

    function drawDish() {
      ctx.clearRect(0, 0, SIZE, SIZE);

      const bg = ctx.createRadialGradient(CX, CY, DISH_RADIUS * 0.1, CX, CY, DISH_RADIUS * 1.15);
      bg.addColorStop(0, '#ffffff');
      bg.addColorStop(1, '#e5edf5');
      ctx.fillStyle = bg;
      ctx.fillRect(0, 0, SIZE, SIZE);

      ctx.save();
      ctx.beginPath();
      ctx.arc(CX, CY, DISH_RADIUS + 22, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(100, 130, 160, 0.12)';
      ctx.fill();
      ctx.restore();

      const agar = ctx.createRadialGradient(CX, CY, DISH_RADIUS * 0.12, CX, CY, DISH_RADIUS);
      agar.addColorStop(0, '#f7edc3');
      agar.addColorStop(1, '#ebd98f');
      ctx.beginPath();
      ctx.arc(CX, CY, DISH_RADIUS, 0, Math.PI * 2);
      ctx.fillStyle = agar;
      ctx.fill();

      if (showHeatInput.checked) {
        const sheen = ctx.createRadialGradient(CX - DISH_RADIUS * 0.25, CY - DISH_RADIUS * 0.25, 0, CX, CY, DISH_RADIUS);
        sheen.addColorStop(0, 'rgba(255,255,255,0.30)');
        sheen.addColorStop(1, 'rgba(255,255,255,0.02)');
        ctx.beginPath();
        ctx.arc(CX, CY, DISH_RADIUS, 0, Math.PI * 2);
        ctx.fillStyle = sheen;
        ctx.fill();
      }

      ctx.save();
      ctx.beginPath();
      ctx.arc(CX, CY, DISH_RADIUS, 0, Math.PI * 2);
      ctx.clip();

      if (showGridInput.checked) {
        ctx.strokeStyle = 'rgba(60, 80, 90, 0.08)';
        ctx.lineWidth = 1;
        for (let x = 0; x <= GRID; x += 6) {
          const px = x * CELL;
          ctx.beginPath();
          ctx.moveTo(px, 0);
          ctx.lineTo(px, SIZE);
          ctx.stroke();
        }
        for (let y = 0; y <= GRID; y += 6) {
          const py = y * CELL;
          ctx.beginPath();
          ctx.moveTo(0, py);
          ctx.lineTo(SIZE, py);
          ctx.stroke();
        }
      }

      for (let y = 0; y < GRID; y++) {
        for (let x = 0; x < GRID; x++) {
          if (!insideDish(x, y)) continue;
          const v = cells[idx(x, y)];
          if (v <= 0.01) continue;

          const { px, py } = cellCenter(x, y);
          const r = CELL * (0.42 + v * 0.6);
          const alpha = 0.18 + v * 0.72;
          const shade = Math.round(170 - v * 95);
          const green = Math.round(205 - v * 70);
          const blue = Math.round(135 - v * 60);

          ctx.fillStyle = `rgba(${shade - 30}, ${green}, ${blue}, ${alpha})`;
          ctx.beginPath();
          ctx.arc(px, py, r, 0, Math.PI * 2);
          ctx.fill();
        }
      }

      if (antibioticOn) {
        const ring = ctx.createRadialGradient(CX, CY, ANTIBIOTIC_RADIUS, CX, CY, ANTIBIOTIC_EFFECT_RADIUS);
        ring.addColorStop(0, 'rgba(240,248,255,0.9)');
        ring.addColorStop(0.25, 'rgba(220,235,248,0.65)');
        ring.addColorStop(1, 'rgba(220,235,248,0)');
        ctx.fillStyle = ring;
        ctx.beginPath();
        ctx.arc(CX, CY, ANTIBIOTIC_EFFECT_RADIUS, 0, Math.PI * 2);
        ctx.fill();

        ctx.beginPath();
        ctx.arc(CX, CY, ANTIBIOTIC_RADIUS, 0, Math.PI * 2);
        ctx.fillStyle = '#f7fbff';
        ctx.fill();
        ctx.strokeStyle = '#9bb6cf';
        ctx.lineWidth = 3;
        ctx.stroke();
      }

      ctx.restore();

      ctx.beginPath();
      ctx.arc(CX, CY, DISH_RADIUS, 0, Math.PI * 2);
      ctx.lineWidth = 10;
      ctx.strokeStyle = '#adc0d0';
      ctx.stroke();

      ctx.beginPath();
      ctx.arc(CX, CY, DISH_RADIUS + 10, 0, Math.PI * 2);
      ctx.lineWidth = 4;
      ctx.strokeStyle = 'rgba(255,255,255,0.8)';
      ctx.stroke();

      ctx.beginPath();
      ctx.arc(CX - DISH_RADIUS * 0.22, CY - DISH_RADIUS * 0.3, DISH_RADIUS * 0.22, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(255,255,255,0.16)';
      ctx.fill();
    }

    function animate(ts) {
      if (!lastTime) lastTime = ts;
      const dt = Math.min(1.6, (ts - lastTime) / 16.6667);
      lastTime = ts;

      if (running) {
        stepSimulation(dt);
      }

      drawDish();
      requestAnimationFrame(animate);
    }

    function resetSimulation() {
      makeGrid();
      elapsedHours = 0;
      steps = 0;
      lastTime = 0;
      running = false;
      seedColonies(Number(coloniesInput.value));
      updateReadouts();
      occupiedStat.textContent = '0%';
      populationStat.textContent = '0';
      growthStat.textContent = '0.00';
      timeStat.textContent = '0.0 h';
      phaseBadge.textContent = 'Phase: exponential';
      drawDish();
    }

    playPauseBtn.addEventListener('click', () => {
      running = !running;
      updatePlayPauseButton();
    });

    resetBtn.addEventListener('click', resetSimulation);

    step1Btn.addEventListener('click', () => {
      advanceHours(1);
    });

    step10Btn.addEventListener('click', () => {
      advanceHours(10);
    });

    seedBtn.addEventListener('click', () => {
      seedColonies(1);
    });

    antibioticBtn.addEventListener('click', () => {
      antibioticOn = !antibioticOn;
      updateReadouts();
    });

    [speedInput, coloniesInput, nutrientsInput, moistureInput, temperatureInput, antibioticStrengthInput, showGridInput, showHeatInput, edgePenaltyInput].forEach(el => {
      el.addEventListener('input', updateReadouts);
    });

    canvas.addEventListener('click', (event) => {
      const rect = canvas.getBoundingClientRect();
      const scaleX = canvas.width / rect.width;
      const scaleY = canvas.height / rect.height;
      const mx = (event.clientX - rect.left) * scaleX;
      const my = (event.clientY - rect.top) * scaleY;

      const dx = mx - CX;
      const dy = my - CY;
      if (Math.hypot(dx, dy) > DISH_RADIUS) return;

      const x = Math.floor(mx / CELL);
      const y = Math.floor(my / CELL);
      for (let oy = -2; oy <= 2; oy++) {
        for (let ox = -2; ox <= 2; ox++) {
          const nx = x + ox;
          const ny = y + oy;
          if (!inBounds(nx, ny) || !insideDish(nx, ny)) continue;
          const d = Math.hypot(ox, oy);
          if (d <= 2.4) {
            const strength = Math.max(0, 0.5 - d * 0.12 + Math.random() * 0.08);
            cells[idx(nx, ny)] = Math.max(cells[idx(nx, ny)], strength);
          }
        }
      }
    });

    resetSimulation();
    requestAnimationFrame(animate);
  </script>
</body>
